# ──────────────────────────────────────────────────────────────────────────
#  City Wallet — environment template
#  Copy this file to `.env` and fill in the values you need.
#  Never commit real keys.
#
#  Two scopes live in this file:
#   • EXPO_PUBLIC_*  →  bundled into the React Native client. NOT secret.
#   • <bare names>   →  read only by server/redeemApi.js. Keep secret.
# ──────────────────────────────────────────────────────────────────────────

# ─── Client-side: live signal providers ─────────────────────────────────

# OpenWeatherMap free API (https://openweathermap.org/api)
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Ticketmaster Discovery API (https://developer.ticketmaster.com/)
EXPO_PUBLIC_TICKETMASTER_API_KEY=

# Optional — legacy Eventbrite token (only used by the eventbrite service).
EXPO_PUBLIC_EVENTBRITE_API_TOKEN=

# Local Ollama model used by the offer backend.
# Run `ollama list` to see what is installed; the value below is a default
# that exists in most setups.
EXPO_PUBLIC_OLLAMA_MODEL=gemma4:e2b

# Optional — override offer-generation backend host.
# LEAVE EMPTY for normal Expo dev: the app auto-detects the host from the
# Expo dev server URL, so wifi/IP changes do not break the live offer flow.
# Set explicitly only for emulators/CI:
#   Android emulator: http://10.0.2.2:8787
#   iOS simulator:    http://127.0.0.1:8787
EXPO_PUBLIC_OFFER_API_BASE_URL=

# Optional — separate redeem API host (defaults to the offer host).
EXPO_PUBLIC_REDEEM_API_BASE_URL=

# Default city label used until GPS resolves (purely cosmetic).
EXPO_PUBLIC_DEFAULT_CITY=Stuttgart

# ─── Client-side: smart push trigger rules ──────────────────────────────
# All optional — sensible defaults applied if unset.

# Minimum minutes between two pushes (default 15).
EXPO_PUBLIC_PUSH_COOLDOWN_MIN=15

# Required Payone quiet ratio (0..1) for a push (default 0.25 → 25% below normal).
EXPO_PUBLIC_PUSH_QUIET_RATIO=0.25

# Maximum walking distance in meters for a push (default 600).
EXPO_PUBLIC_PUSH_DISTANCE_M=600

# Optional (default off): enables in-app alert fallback for Expo Go Android
# where native push is unsupported. Set to 1 only for demos.
EXPO_PUBLIC_ENABLE_EXPO_GO_PUSH_FALLBACK=0

# Optional — route Overpass requests through Zyte API to avoid local IP blocking.
# WARNING: EXPO_PUBLIC_* vars are bundled into the client app, so use this only
# for demos/prototypes. For production, move this key to a backend relay.
EXPO_PUBLIC_ZYTE_API_KEY=

# ─── Server-side secrets — used only by server/redeemApi.js ─────────────
#  These are NOT bundled into the client because they have no
#  EXPO_PUBLIC_ prefix. Treat them like passwords.

# Payone Payment API (https://docs.payone.com/) — server-2-server only.
PAYONE_PSPID=
PAYONE_API_KEY_ID=
PAYONE_API_SECRET=
# Sandbox: https://api.preprod.payone.com/v2
# Live:    https://api.payone.com/v2
PAYONE_API_BASE_URL=https://api.preprod.payone.com/v2

# ──────────────────────────────────────────────────────────────────────────
#  Notes
#   • Real merchants in live mode are pulled from OpenStreetMap's Overpass
#     API. No key required.  https://overpass-api.de
#   • On-device preferences are stored under AsyncStorage key
#     "city-wallet/preferences/v1". They never leave the device.
#   • Push notifications require a development build on Android — Expo Go
#     no longer ships the native push code (SDK 53+).
# ──────────────────────────────────────────────────────────────────────────
