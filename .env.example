# Get a key at https://openweathermap.org/api
# Never commit real keys; copy this file to .env and fill in values.
EXPO_PUBLIC_OPENWEATHER_API_KEY=
# Ticketmaster Discovery API key from https://developer.ticketmaster.com/
EXPO_PUBLIC_TICKETMASTER_API_KEY=
# Local model name used by backend when generating offer copy
# Example: gemma3:4b (set to your installed local model)
EXPO_PUBLIC_OLLAMA_MODEL=
# Optional override for token validation API
# Android emulator default is http://10.0.2.2:8787 ; iOS/web default is http://localhost:8787
EXPO_PUBLIC_REDEEM_API_BASE_URL=
# Optional override for offer generation API (defaults to same backend host as redeem)
EXPO_PUBLIC_OFFER_API_BASE_URL=
